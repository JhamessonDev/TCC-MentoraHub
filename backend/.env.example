# ================================
# MENTORA — Variáveis de Ambiente
# ================================

# Aplicação
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Banco de Dados
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=mentora_user
DB_PASSWORD=mentora_pass
DB_DATABASE=mentora_db

# JWT
JWT_SECRET=mentora_super_secret_key_2026
JWT_EXPIRES_IN=7d

# Elasticsearch / Kibana (logs)
ELASTIC_HOST=http://localhost:9200
ELASTIC_INDEX=mentora-logs

# App
APP_NAME=Mentora API
APP_VERSION=1.0.0
